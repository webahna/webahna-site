---
import webahnaLogo from "../assets/logo.svg";
import pointApp from "../assets/point-app.jpg";
import intrepido from "../assets/intrepido.jpg";
import dashboard from "../assets/dashboard.jpg";
---

<!-- NAV -->
<>
  <nav>
    <a href="/" class="nav-logo">
      <img src={webahnaLogo.src} alt="Webahna Logo" class="logo" />
    </a>
    <ul class="nav-links">
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#proceso">Proceso</a></li>
      <li><a href="#proyectos">Proyectos</a></li>
      <li><a href="#precios">Precios</a></li>
    </ul>
    <a href="#contacto" class="btn-nav">Hablemos →</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>

    <div class="badge">Disponible para nuevos proyectos</div>

    <h1>
      Webs que<br />
      <span>convierten,</span><br />
      no que decoran.
    </h1>

    <p>
      Diseño y desarrollo web a medida para negocios que quieren resultados.
      Código limpio, diseño estratégico, entrega puntual.
    </p>

    <div class="hero-cta">
      <a href="#contacto" class="btn-primary">Iniciar proyecto →</a>
      <a href="#proyectos" class="btn-outline">Ver portafolio</a>
    </div>

    <div class="hero-stats">
      <div class="stat-item">
        <strong>+20</strong>
        <span>Proyectos entregados</span>
      </div>
      <div class="stat-item">
        <strong>100%</strong>
        <span>Clientes satisfechos</span>
      </div>
      <div class="stat-item">
        <strong>+4</strong>
        <span>Años de experiencia</span>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios">
    <p class="section-label">// Servicios</p>
    <h2 class="section-title">Todo lo que tu negocio necesita en la web.</h2>
    <p class="section-subtitle">
      Desde la idea hasta el lanzamiento. Cada proyecto se trata con atención al
      detalle y enfoque en resultados reales.
    </p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🎨</div>
        <h3>Desarrollo Web Full Stack</h3>
        <p>
          Sitios web rápidos, escalables y optimizados para generar resultados
          reales. Desarrollo frontend y backend a medida.
        </p>
        <span class="service-tag">Next.js · React · Node.js · NestJS</span>
      </div>
      <div class="service-card">
        <div class="service-icon">⚡</div>
        <h3>Tiendas Online</h3>
        <p>
          E-commerce completo con catálogo, carrito, pagos, envíos y panel de
          administración.
        </p>
        <span class="service-tag"
          >E-commerce personalizado · Shopify · WooCommerce</span
        >
      </div>
      <div class="service-card">
        <div class="service-icon">🛒</div>
        <h3>Diseño UX/UI</h3>
        <p>
          Interfaces modernas enfocadas en conversión, experiencia de usuario y
          usabilidad.
        </p>
        <span class="service-tag">Figma · Wireframes · Prototipos</span>
      </div>
      <div class="service-card">
        <div class="service-icon">🔍</div>
        <h3>SEO y Rendimiento</h3>
        <p>
          Optimización técnica para mejorar posicionamiento, velocidad y
          experiencia de usuario.
        </p>
        <span class="service-tag">Core Web Vitals · SEO Técnico</span>
      </div>
      <div class="service-card">
        <div class="service-icon">📱</div>
        <h3>Automatización y Sistemas</h3>
        <p>
          Desarrollo de paneles administrativos, APIs, sistemas internos y
          herramientas empresariales.
        </p>
        <span class="service-tag">APIs · Bases de Datos · Dashboards</span>
      </div>
      <div class="service-card">
        <div class="service-icon">🔧</div>
        <h3>Soporte y Mantenimiento</h3>
        <p>
          Actualizaciones, monitoreo, seguridad y mejoras continuas para tu
          proyecto.
        </p>
        <span class="service-tag">Soporte continuo · Optimización</span>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section id="proceso" class="process-section">
    <p class="section-label">// Cómo trabajamos</p>
    <h2 class="section-title">Un proceso claro, sin sorpresas.</h2>
    <p class="section-subtitle">
      Cuatro etapas que llevan tu proyecto del concepto al lanzamiento de forma
      ordenada y transparente.
    </p>

    <div class="process-steps">
      <div class="process-step">
        <p class="step-num">01</p>
        <div class="step-dot"></div>
        <h3>Descubrimiento</h3>
        <p>
          Entendemos tu negocio, objetivos y audiencia. Definimos el alcance y
          el plan de trabajo juntos.
        </p>
      </div>
      <div class="process-step">
        <p class="step-num">02</p>
        <div class="step-dot"></div>
        <h3>Diseño</h3>
        <p>
          Creamos wireframes y el diseño visual final en Figma. Tú apruebas
          antes de que se escriba una línea de código.
        </p>
      </div>
      <div class="process-step">
        <p class="step-num">03</p>
        <div class="step-dot"></div>
        <h3>Desarrollo</h3>
        <p>
          Construimos tu sitio con código limpio y escalable. Pruebas en cada
          etapa para garantizar calidad.
        </p>
      </div>
      <div class="process-step">
        <p class="step-num">04</p>
        <div class="step-dot"></div>
        <h3>Lanzamiento</h3>
        <p>
          Publicamos, optimizamos y te entregamos todo. Soporte post-lanzamiento
          incluido siempre.
        </p>
      </div>
    </div>
  </section>

  <!-- PORTAFOLIO -->
  <section id="proyectos">
    <p class="section-label">// Proyectos</p>
    <h2 class="section-title">Trabajo que habla por sí solo.</h2>
    <p class="section-subtitle">
      Una muestra de proyectos recientes. Cada uno diseñado con estrategia, no
      solo estética.
    </p>

    <div class="portfolio-grid">
      <div class="portfolio-item">
        <div
          class="portfolio-mock"
          style="min-height: 400px; max-height: 400px;"
        >
          <!-- <div class="mock-bar blue"></div>
          <div class="mock-bar short"></div> -->
          <div class="mock-image-area" style="font-size: 3rem;">
            <img src={intrepido.src} alt="" style="object-fit: contain;" />
          </div>
          <!-- <div style="display:flex; gap:8px;">
            <div class="mock-bar" style="flex:1; height:8px;"></div>
            <div
              class="mock-bar"
              style="flex:1; height:8px; background:rgba(75,95,232,0.4);"
            >
            </div>
          </div> -->
        </div>
        <div class="portfolio-label">
          <h4>IntrepidoMX — E-commerce</h4>
          <span>Next.js · React · TypeScript · Tailwind CSS</span>
        </div>
      </div>
      <div class="portfolio-item">
        <div class="portfolio-mock">
          <!-- <div class="mock-bar blue" style="width:45%;"></div> -->
          <div
            class="mock-image-area"
            style="font-size:2rem; min-height:130px;"
          >
            <img src={dashboard.src} alt="" />
          </div>
        </div>
        <div class="portfolio-label">
          <h4>Dashboard Analytics</h4>
          <span>Node.js · Express.js · Pug · ORM Sequelize</span>
        </div>
      </div>
      <div class="portfolio-item">
        <div class="portfolio-mock">
          <div class="mock-bar blue" style="width:55%;"></div>
          <div
            class="mock-image-area"
            style="font-size:2rem; min-height:130px;"
          >
            <img src={pointApp.src} alt="" />
          </div>
        </div>
        <div class="portfolio-label">
          <h4>Point App - Sistema de Entregas de Garrafones de Agua</h4>
          <span>Diseño UX/UI</span>
        </div>
      </div>
    </div>
  </section>
</>

<!-- TECH STACK -->
<section class="tech-section">
  <p class="section-label">// Stack tecnológico</p>
  <h2 class="section-title">Las herramientas que usamos.</h2>
  <p class="section-subtitle" style="margin-bottom:2rem;">
    Tecnología probada para cada tipo de proyecto. Elegimos lo que mejor sirve a
    tus objetivos.
  </p>

  <div class="tech-grid">
    <div class="tech-pill">
      <span class="tech-dot" style="background:#000;border:1px solid #555;"
      ></span>Next.js
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#61DAFB;"></span>React
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#FF5A1F;"></span>Astro
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#3178C6;"></span>TypeScript
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#339933;"></span>Node.js
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#E0234E;"></span>NestJS
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#2D3748;"></span>Prisma
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#00758F;"></span>MySQL
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#FF9900;"></span>AWS
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#F38020;"></span>Cloudflare
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#635BFF;"></span>Stripe
    </div>

    <div class="tech-pill">
      <span class="tech-dot" style="background:#F24E1E;"></span>Figma
    </div>
  </div>
</section>

<!-- PRECIOS -->
<section id="precios">
  <p class="section-label">// Precios</p>
  <h2 class="section-title">Inversión transparente.</h2>
  <p class="section-subtitle">
    Sin costos ocultos ni sorpresas. Elige el plan que se adapta a tu momento.
  </p>

  <div class="pricing-grid">
    <div class="pricing-card">
      <h3>Esencial</h3>
      <p style="font-size:0.875rem; color:var(--gray-400);">
        Para emprendedores y startups que arrancan.
      </p>
      <div class="price"><sup>$</sup>1,499</div>
      <p class="price-note">Pago único · Entrega en 1 semana</p>
      <ul class="pricing-features">
        <li>Landing page de 1 página</li>
        <li>Diseño responsive</li>
        <li>Formulario de contacto</li>
        <li>SEO básico</li>
        <li>1 ronda de revisiones</li>
      </ul>
      <a href="#contacto" class="btn-full outline">Comenzar</a>
    </div>

    <div class="pricing-card featured">
      <span class="popular-badge">⭐ Más popular</span>
      <h3>Profesional</h3>
      <p style="font-size:0.875rem; color:var(--gray-400);">
        Para negocios que necesitan presencia completa.
      </p>
      <div class="price"><sup>$</sup>3,499</div>
      <p class="price-note">Pago único · Entrega en 2 semanas</p>
      <ul class="pricing-features">
        <li>Sitio multi-página (hasta 8)</li>
        <li>Diseño UI/UX personalizado</li>
        <li>Blog o sección de noticias</li>
        <li>SEO técnico avanzado</li>
        <li>Google Analytics integrado</li>
        <li>3 rondas de revisiones</li>
      </ul>
      <a href="#contacto" class="btn-full solid">Comenzar →</a>
    </div>

    <div class="pricing-card">
      <h3>E-Commerce</h3>
      <p style="font-size:0.875rem; color:var(--gray-400);">
        Vende en línea desde el día uno.
      </p>
      <div class="price"><sup>$</sup>9,999</div>
      <p class="price-note">Pago único · Entrega en 4-6 semanas</p>
      <ul class="pricing-features">
        <li>Tienda online completa</li>
        <li>Hasta 100 productos o más</li>
        <li>Pasarela de pago integrada</li>
        <li>Panel de administración</li>
        <li>SEO para e-commerce</li>
        <li>Capacitación incluida</li>
      </ul>
      <a href="#contacto" class="btn-full outline">Comenzar</a>
    </div>
  </div>
</section>

<!-- CTA FINAL -->
<section id="contacto" class="cta-section">
  <div class="cta-glow"></div>
  <p class="section-label">// Hablemos</p>
  <h2>¿Listo para crear algo increíble?</h2>
  <p>
    Cuéntanos sobre tu proyecto. La primera consulta es completamente gratuita.
  </p>
  <div class="cta-actions">
    <a
      href="mailto:hola@webahna.com"
      class="btn-primary"
      style="font-size:1.05rem; padding:1rem 2.25rem;"
    >
      Escribir a hola@webahna.com →
    </a>
    <a href="https://wa.me/526681940855" class="btn-outline">WhatsApp</a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">
    <img src={webahnaLogo.src} alt="Webahna Logo" class="logo" />
  </div>
  <ul class="footer-links">
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#proceso">Proceso</a></li>
    <li><a href="#proyectos">Proyectos</a></li>
    <li><a href="#precios">Precios</a></li>
    <li><a href="#contacto">Contacto</a></li>
  </ul>
  <p class="footer-copy">© 2026 Webahna®. Todos los derechos reservados.</p>
</footer>

<style>
  body {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --blue: #4b5fe8;
    --blue-light: #6b7ff5;
    --blue-pale: #e8ebff;
    --navy: #0d1117;
    --navy-mid: #161b26;
    --navy-soft: #1e2535;
    --white: #ffffff;
    --gray-100: #f5f6fa;
    --gray-200: #e4e6ef;
    --gray-400: #9ea3b5;
    --gray-600: #5c6070;
    --font: "Plus Jakarta Sans", sans-serif;
    --mono: "DM Mono", monospace;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font);
    background: var(--navy);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 5%;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--white);
  }

  .logo {
    height: 40px;
  }

  .logo-mark {
    width: 36px;
    height: 36px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--gray-400);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--white);
  }

  .btn-nav {
    background: var(--blue);
    color: var(--white);
    border: none;
    border-radius: 8px;
    padding: 0.6rem 1.25rem;
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-nav:hover {
    background: var(--blue-light);
  }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 5% 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(75, 95, 232, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(75, 95, 232, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(
      ellipse 80% 60% at 50% 0%,
      black 40%,
      transparent 100%
    );
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse,
      rgba(75, 95, 232, 0.18) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(75, 95, 232, 0.12);
    border: 1px solid rgba(75, 95, 232, 0.3);
    border-radius: 100px;
    padding: 0.3rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--blue-light);
    font-family: var(--mono);
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .badge::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue-light);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  .hero h1 {
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 820px;
    margin-bottom: 1.5rem;
  }

  .hero h1 span {
    color: var(--blue-light);
  }

  .hero p {
    font-size: 1.15rem;
    color: var(--gray-400);
    max-width: 540px;
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--blue);
    color: var(--white);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    padding: 0.9rem 2rem;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition:
      background 0.2s,
      transform 0.15s;
  }
  .btn-primary:hover {
    background: var(--blue-light);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    cursor: pointer;
    padding: 0.9rem 2rem;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition:
      border-color 0.2s,
      background 0.2s;
  }
  .btn-outline:hover {
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.05);
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .stat-item strong {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.03em;
  }
  .stat-item span {
    font-size: 0.875rem;
    color: var(--gray-400);
  }

  /* ─── SERVICES ─── */
  section {
    padding: 100px 5%;
  }
  #servicios {
    padding: 0px 5% 100px 5%;
  }
  .section-label {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--blue-light);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    max-width: 560px;
  }

  .section-subtitle {
    color: var(--gray-400);
    font-size: 1.05rem;
    max-width: 500px;
    margin-bottom: 3.5rem;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 2fr));
    gap: 1.5px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    overflow: hidden;
  }

  .service-card {
    background: var(--navy-mid);
    padding: 2rem;
    transition: background 0.2s;
    position: relative;
  }
  .service-card:hover {
    background: var(--navy-soft);
  }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(75, 95, 232, 0.15);
    border: 1px solid rgba(75, 95, 232, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    font-size: 1.4rem;
  }

  .service-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--gray-400);
    line-height: 1.65;
  }

  .service-tag {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blue-light);
    background: rgba(75, 95, 232, 0.1);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }

  /* ─── PROCESS ─── */
  .process-section {
    background: var(--navy-mid);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0;
